{
  "type": "module",
  "name": "achievements-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.33.0",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "next dev --hostname achievements-next.lvh.me",
    "build": "next build",
    "start": "next start",
