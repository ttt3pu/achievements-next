    "react": "19.2.3",
    "react-datepicker": "9.1.0",
    "react-dom": "19.2.3",
    "react-toastify": "11.0.5",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@faker-js/faker": "10.4.0",
    "@next/eslint-plugin-next": "16.2.4",
    "@prisma/client": "7.7.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "24.12.2",
    "@types/pg": "8.11.14",
    "@types/react": "19.2.14",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.0",
    "markdown-it": "14.1.1",
    "postcss": "8.5.9",
    "prettier": "3.8.2",
    "react-icons": "5.5.0",
    "stylelint": "17.7.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.2.2",
